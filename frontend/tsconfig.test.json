{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "noEmit": false,
    "outDir": "./dist/test-output",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "types": ["node"],
    "lib": ["ES2023", "DOM"]
  },
  "include": [
    "src/api/audienceAnalysis.ts",
    "src/api/types.ts",
    "src/components/AgentJourneyPanel.tsx",
    "tests/**/*.ts"
  ]
}
